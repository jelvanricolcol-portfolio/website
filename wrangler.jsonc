{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jelvan-portfolio",
  "main": "worker/index.ts",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": false
  },
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI"
  }
}
